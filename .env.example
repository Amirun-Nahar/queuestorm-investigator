# ============================================================
# QueueStorm Investigator – Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================================

# --- Option 1: Gemini (default, recommended) ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Option 2: OpenAI (used only if GEMINI_API_KEY is not set) ---
# For OpenAI fallback
# OPENAI_API_KEY=sk-your-openai-key-here

# Bypass LLM and return mock responses for testing (true/false)
MOCK_AI=false

# Model to use (optional – defaults to gemini-2.0-flash)
# For OpenAI, set to e.g. gpt-4o-mini
MODEL=gemini-2.0-flash
